{
  "name": "@calumba/herold-cli",
  "version": "0.3.0",
  "description": "CLI for Herold.at firm and person search.",
  "type": "module",
  "bin": {
    "herold": "dist/bin.js"
  },
  "files": [
    "dist",
    "docs",
    ".agents/skills",
    "README.md",
    "CHANGELOG.md",
    "AGENTS.md"
  ],
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/calumba-holding/herold-cli.git"
  },
  "bugs": {
    "url": "https://github.com/calumba-holding/herold-cli/issues"
  },
  "homepage": "https://github.com/calumba-holding/herold-cli#readme",
  "keywords": [
    "herold",
    "cli",
    "search",
    "yellow-pages",
    "austria"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.build.json",
    "dev": "tsx src/bin.ts",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "release:patch": "node scripts/release.mjs patch",
    "release:minor": "node scripts/release.mjs minor",
    "release:major": "node scripts/release.mjs major"
  },
  "dependencies": {},
  "devDependencies": {
    "@eslint/js": "latest",
    "@types/node": "latest",
    "eslint": "latest",
    "typescript": "latest",
    "typescript-eslint": "latest",
    "tsx": "latest",
    "vitest": "latest"
  },
  "engines": {
    "node": ">=20"
  }
}
